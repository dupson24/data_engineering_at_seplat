-- ============================================================
-- ADF LOOKUP QUERY  (paste directly into LKP_GetWatermark)
-- Returns all active tables for ForEach iteration
-- ============================================================
SELECT
    table_name,
    last_load_date,
    last_load_status,
    last_pipeline_run_id
FROM phishme_security.watermark
WHERE is_active = 1
ORDER BY table_name;


-- ============================================================
-- usp_set_watermark  (called by every CDC stored procedure)
-- Signature matches calls in store_proc.sql
-- ============================================================
CREATE OR ALTER PROCEDURE phishme_security.usp_set_watermark
    @table_name         NVARCHAR(128),
    @load_date          DATE,
    @load_datetime      DATETIME,
    @status             NVARCHAR(20),
    @rows_inserted      INT,
    @rows_updated       INT,
    @rows_deleted       INT,
    @source_path        NVARCHAR(500),
    @dq_passed          BIT,
    @rows_rejected      INT,
    @proc_name          NVARCHAR(256),
    @pipeline_run_id    NVARCHAR(128),
    @trigger_type       NVARCHAR(50),
    @error_message      NVARCHAR(1000),
    @error_code         NVARCHAR(50)
AS
BEGIN
    SET NOCOUNT ON;

    IF EXISTS (SELECT 1 FROM phishme_security.watermark WHERE table_name = @table_name)
        UPDATE phishme_security.watermark
        SET
            last_load_date       = @load_date,
            last_load_datetime   = @load_datetime,
            last_load_status     = @status,
            last_pipeline_run_id = @pipeline_run_id,
            last_proc_name       = @proc_name,
            last_source_path     = @source_path,
            error_message        = @error_message,
            error_code           = @error_code,
            updated_at           = GETDATE()
        WHERE table_name = @table_name;
    ELSE
        INSERT INTO phishme_security.watermark
            (table_name, last_load_date, last_load_datetime, last_load_status,
             last_pipeline_run_id, last_proc_name, last_source_path,
             error_message, error_code)
        VALUES
            (@table_name, @load_date, @load_datetime, @status,
             @pipeline_run_id, @proc_name, @source_path,
             @error_message, @error_code);
END;
GO